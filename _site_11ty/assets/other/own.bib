@inproceedings{kirschner_2021_NotionCorrect,
  title = {Notion on the Correct Use of the Robot Effective Mass in the Safety Context and Comments on ISO/TS 15066},
  booktitle = {2021 IEEE International Conference on Intelligence and Safety for Robotics (ISR)},
  author = {Kirschner, Robin Jeanne and Mansfeld, Nico and Pe{\~n}a, Guillermo G{\'o}mez and Abdolshah, Saeed and Haddadin, Sami},
  year = 2021,
  month = mar,
