  langid = {english},
  keywords = {Aerospace engineering,Computer science,Electrical and electronic engineering,Mechanical engineering},
  file = {/home/jakob/Nextcloud/Promotion/Zotero/Promotion/Reinforcement Learning/Impressive Demos/Kaufmann_2023_Champion-level drone racing using deep reinforcement learning.pdf}
}

