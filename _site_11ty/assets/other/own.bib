@article{duma_2005_DeterminationSignificant,
  title = {Determination of Significant Parameters for Eye Injury Risk from Projectiles},
  author = {Duma, Stefan M. and Ng, Tracy P. and Kennedy, Eric A. and Stitzel, Joel D. and Herring, Ian P. and Kuhn, Ferenc},
  year = 2005,
  month = oct,
  journal = {Journal of Trauma and Acute Care Surgery},
  volume = {59},
  number = {4},
  pages = {960},
  issn = {2163-0755},
  doi = {10.1097/01.ta.0000174830.55282.32},
  url = {https://journals.lww.com/jtrauma/abstract/2005/10000/determination_of_significant_parameters_for_eye.23.aspx},
  urldate = {2024-12-04},
  abstract = {Background:~           Eye injuries affect a large proportion of the population and are expensive to treat. This article presents a parametric analysis of experimental data to determine the most significant factors for predicting ocular injuries or tissue lesions.           Methods:~           Using logistic regression, statistical values were generated to determine significant projectile characteristics for predicting ocular injury in published studies. Projectiles included BBs, metal rods, and foam particles with velocities ranging from 2 m/s to 122 m/s.           Results:~           A normalized energy (energy per projected area) value was found as the best predictor for ocular injury. Using this predictor, a 50\% injury risk of corneal abrasion, lens dislocation, hyphema, retinal damage, and globe rupture was found to be 1,503 kg/s2, 19,194 kg/s2, 20,188 kg/s2, 30,351 kg/s2, and 23,771 kg/s2, respectively.           Conclusion:~           Normalized energy was the most significant predictor of injury type and tissue lesion. This finding is of great value for history-taking management triaging and as a design aid to minimize the risk of ocular injury for consumer products.},
  langid = {american},
  file = {/home/jakob/Nextcloud/Promotion/Zotero/Promotion/Robotics/Human Injury Studies/Duma_2005_Determination of Significant Parameters for Eye Injury Risk from Proje.pdf;/home/jakob/Zotero/storage/Y466HCME/determination_of_significant_parameters_for_eye.23.html}
}

