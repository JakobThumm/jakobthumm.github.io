@inproceedings{wu_2020_SharedImpedance,
  title = {Shared Impedance Control Based on Reinforcement Learning in a Human-Robot Collaboration Task},
  booktitle = {Advances in Service and Industrial Robotics},
  author = {Wu, Min and He, Yanhao and Liu, Steven},
  editor = {Berns, Karsten and G{\"o}rges, Daniel},
  year = 2020,
  pages = {95--103},
  abstract = {In this work a shared impedance control scheme for a hybrid human-robot team is designed for transporting a rigid workpiece to a desired position. Within the scope of proposed control structure, both human and robot are regarded as mechanical impedance and their parameters are adapted continuously in real-time. Reinforcement learning is used to find an impedance parameter set for the whole team to optimize a task-orient cost function. Then the learned parameters are further adjusted by taking human's disagreement into consideration. The proposed method is aimed to reduce human's control effort during collaboration and be flexible to variation of the task or environment. Experimental results are presented to illustrate the performance.}
}

@misc{wu_2025_OutofDistributionGeneralization,
