  title = {Belief Control Barrier Functions for Risk-Aware Control},
  author = {Vahs, Matti and Pek, Christian and Tumova, Jana},
  year = 2023,
  month = dec,
  journal = {IEEE Robotics and Automation Letters},
  volume = {8},
  number = {12},
