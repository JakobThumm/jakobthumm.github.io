  shorttitle = {Toward Dexterous Manipulation With Augmented Adaptive Synergies},
  author = {Santina, Cosimo Della and Piazza, Cristina and Grioli, Giorgio and Catalano, Manuel G. and Bicchi, Antonio},
  year = 2018,
  month = oct,
  journal = {IEEE Transactions on Robotics},
  volume = {34},
