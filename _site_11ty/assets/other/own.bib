@article{ghanbarzadeh_2024_SafePhysical,
  title = {Safe Physical Human--Robot Interaction through Variable Impedance Control Based on ISO/TS 15066},
  author = {Ghanbarzadeh, Armin and Najafi, Esmaeil},
  year = 2024,
