@misc{chen_2026_ABotPhysWorldInteractive,
  title = {ABot-PhysWorld: Interactive World Foundation Model for Robotic Manipulation with Physics Alignment},
  shorttitle = {ABot-PhysWorld},
  author = {Chen, Yuzhi and Chen, Ronghan and Huo, Dongjie and Yang, Yandan and Qi, Dekang and Liu, Haoyun and Lin, Tong and Zeng, Shuang and Xiao, Junjin and Chang, Xinyuan and Xiong, Feng and Wei, Xing and Ma, Zhiheng and Xu, Mu},
  year = 2026,
  month = mar,
  number = {arXiv:2603.23376},
