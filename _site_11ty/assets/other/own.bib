  author = {Li, Jiachen and Hua, Chuanbo and Ma, Hengbo and Park, Jinkyoo and Dax, Victoria and Kochenderfer, Mykel J.},
  year = 2024,
  month = jan,
  number = {arXiv:2401.12275},
