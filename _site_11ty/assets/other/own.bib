  booktitle = {2023 11th RSI International Conference on Robotics and Mechatronics (ICRoM)},
  author = {Golshani, Ali and Kouhkord, Afshin and Ghanbarzadeh, Armin and Najafi, Esmaeil},
  year = 2023,
  month = dec,
  pages = {279--284},
  issn = {2572-6889},
  doi = {10.1109/ICRoM60803.2023.10412570},
  url = {https://ieeexplore.ieee.org/document/10412570},
  urldate = {2024-10-29},
  abstract = {In collaborative robot systems, ensuring operator safety is crucial. This responsibility falls on robot integrators who must identify potential risks and design safety measures to prevent unwanted accidental contact with human operators. The ISO/TS 15066 guideline's Power and Force Limiting mode is instrumental in managing such incidents. This study explored the effectiveness of two control strategies, Sliding Mode Control and Computational Torque Control, within the framework of a six degrees of freedom robot manipulator, considering the design requirements of the power and force limiting mode. Simulation results showed that in the presence of external disturbances, Sliding Mode Controller outperformed in terms of response time, stability, and position tracking, making it more suitable for safety-focused applications in shared workspaces.},
  keywords = {Collaboration,Computed torque control,Force,Human Robot collaboration,ISO/TS 15066,Limiting,Power and force limit,Safety,Sliding mode control,Torque control,Trajectory},
